#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
ensure_homebrew() {
  local brew_bin=""

  if command -v brew >/dev/null 2>&1; then
    brew_bin="$(command -v brew)"
  elif [ -x /opt/homebrew/bin/brew ]; then
    brew_bin="/opt/homebrew/bin/brew"
  elif [ -x /usr/local/bin/brew ]; then
    brew_bin="/usr/local/bin/brew"
  fi

  if [ -z "${brew_bin}" ]; then
    echo "Homebrew not found; installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    case "$(uname -m)" in
      arm64) brew_bin="/opt/homebrew/bin/brew" ;;
      *) brew_bin="/usr/local/bin/brew" ;;
    esac
  fi

  if [ ! -x "${brew_bin}" ]; then
    echo "error: Homebrew install completed, but brew was not found at ${brew_bin}" >&2
    echo "       Check the Homebrew installer output, then re-run chezmoi apply." >&2
    exit 1
  fi

  eval "$("${brew_bin}" shellenv)"

  if ! command -v brew >/dev/null 2>&1; then
    echo "error: brew is still not in PATH after loading shellenv" >&2
    exit 1
  fi
}

write_bootstrap_brewfile() {
  local brewfile="$1"

  cat >"${brewfile}" <<'EOF'
# Generated bootstrap Brewfile - Temporary
# Source: {{ .chezmoi.sourceDir }}/.chezmoidata/packages.yaml

# Taps
{{- range .packages.taps }}
tap {{ . | quote }}
{{- end }}

# Bootstrap brews
{{- range .packages.bootstrap.brews }}
brew {{ . | quote }}
{{- end }}
EOF
}

ensure_homebrew

echo "Updating Homebrew..."
brew update

BOOTSTRAP_BREWFILE="$(mktemp)"
trap 'rm -f "${BOOTSTRAP_BREWFILE}"' EXIT

write_bootstrap_brewfile "${BOOTSTRAP_BREWFILE}"

echo "Installing bootstrap Homebrew formulae..."
brew bundle install --no-upgrade --file="${BOOTSTRAP_BREWFILE}"
{{ else -}}
echo "Skipping Homebrew bootstrap: unsupported OS {{ .chezmoi.os }}."
{{ end -}}
