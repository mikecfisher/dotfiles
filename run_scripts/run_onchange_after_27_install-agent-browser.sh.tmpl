#!/bin/bash
set -euo pipefail

{{ if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
# Install agent-browser after the fnm/Node bootstrap has run.
# https://github.com/vercel-labs/agent-browser

load_homebrew_shellenv() {
  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
  elif [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
}

add_fnm_to_path() {
  local candidate
  for candidate in \
    "${HOME}/.local/share/fnm" \
    "${HOME}/.fnm"; do
    if [ -x "${candidate}/fnm" ]; then
      export PATH="${candidate}:${PATH}"
    fi
  done
}

load_node() {
  add_fnm_to_path

  if command -v fnm >/dev/null 2>&1; then
    eval "$(fnm env --shell bash)"
    fnm install 22 --corepack-enabled
    fnm use 22
    hash -r
  fi

  if ! command -v npm >/dev/null 2>&1; then
    echo "error: npm is required to install agent-browser. Re-run chezmoi apply after fnm/Node setup completes." >&2
    exit 1
  fi
}

load_homebrew_shellenv
load_node

echo "Installing agent-browser globally with npm..."
npm install -g agent-browser

if ! command -v agent-browser >/dev/null 2>&1; then
  echo "error: agent-browser is not available after npm install" >&2
  exit 1
fi

echo "Installing Chrome for Testing for agent-browser..."
agent-browser install

agent-browser --version >/dev/null
{{ else -}}
echo "Skipping agent-browser install: unsupported OS {{ .chezmoi.os }}."
{{ end -}}
