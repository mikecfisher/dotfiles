#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
load_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
  elif [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi

  if ! command -v brew >/dev/null 2>&1; then
    echo "error: Homebrew is required for package installation. Re-run chezmoi apply after Homebrew is installed." >&2
    exit 1
  fi
}

write_core_brewfile() {
  local brewfile="$1"

  cat >"${brewfile}" <<'EOF'
# Generated Brewfile - Temporary
# Source: {{ .chezmoi.sourceDir }}/.chezmoidata/packages.yaml
# Machine type: {{ .machine_type }}

# Taps
{{- range .packages.taps }}
tap {{ . | quote }}
{{- end }}

# Common brews
{{- range .packages.common.brews }}
brew {{ . | quote }}
{{- end }}

# Common casks
{{- range .packages.common.casks }}
cask {{ . | quote }}
{{- end }}

{{- if eq .machine_type "personal" }}
# Personal brews
{{- range .packages.personal.brews }}
brew {{ . | quote }}
{{- end }}

# Personal casks
{{- range .packages.personal.casks }}
cask {{ . | quote }}
{{- end }}
{{- end }}
EOF
}

write_mas_brewfile() {
  local brewfile="$1"

  cat >"${brewfile}" <<'EOF'
# Generated MAS Brewfile - Temporary
# Source: {{ .chezmoi.sourceDir }}/.chezmoidata/packages.yaml
# Machine type: {{ .machine_type }}

{{- range .packages.common.mas }}
mas {{ .name | quote }}, id: {{ .id }}
{{- end }}

{{- if eq .machine_type "personal" }}
{{- range .packages.personal.mas }}
mas {{ .name | quote }}, id: {{ .id }}
{{- end }}
{{- end }}
EOF
}

load_homebrew

CORE_BREWFILE="$(mktemp)"
MAS_BREWFILE="$(mktemp)"
trap 'rm -f "${CORE_BREWFILE}" "${MAS_BREWFILE}"' EXIT

write_core_brewfile "${CORE_BREWFILE}"
write_mas_brewfile "${MAS_BREWFILE}"

echo "Installing remaining Homebrew formulae and casks from generated Brewfile..."
brew bundle install --no-upgrade --file="${CORE_BREWFILE}"

if ! command -v mas >/dev/null 2>&1; then
  echo "Skipping Mac App Store apps: mas is not installed or not in PATH."
elif mas account >/dev/null 2>&1; then
  echo "Installing Mac App Store apps from generated Brewfile..."
  brew bundle install --no-upgrade --file="${MAS_BREWFILE}"
else
  echo "Skipping Mac App Store apps: not signed in to the App Store."
  echo "Sign in, then re-run: chezmoi apply"
fi
{{ else -}}
echo "Skipping Homebrew package installation: unsupported OS {{ .chezmoi.os }}."
{{ end -}}
