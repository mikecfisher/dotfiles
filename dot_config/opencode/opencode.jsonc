{
  "$schema": "https://opencode.ai/config.json",
  // Model configuration
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  // Provider configurations with thinking mode for Sonnet 4.5
  "provider": {
    "anthropic": {
      "name": "Anthropic",
      "models": {
        "claude-sonnet-4-5-20250929": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "claude-sonnet-4-5-deep": {
          "id": "claude-sonnet-4-5-20250929",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 28000
            },
            "maxTokens": 32000
          }
        }
      }
    }
  },
  // MCP Servers - Model Context Protocol integrations
  "mcp": {
    "docker-mcp": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run"
      ],
      "enabled": true
    },
    "polar-sandbox": {
      "type": "local",
      "command": [
        "npx",
        "mcp-remote",
        "https://mcp.polar.sh/mcp/polar-sandbox"
      ],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "/absolute/path/to/your/listium-repo"
      ],
      "enabled": true
      // "environment": { }  // optional, for future tweaks
    }
  },
  // Theme and UI settings
  "theme": "catppuccin",
  "autoupdate": true,
  // Instructions for additional context
  "instructions": [
    "AGENTS.md",
    ".cursor/rules/*.md"
  ],
  // Tool permissions - require confirmation for destructive operations
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  // Agent configurations
  "agent": {
    "build": {
      "mode": "all",
      "description": "Default agent with full tool access for development work",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "webfetch": true
      },
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "mode": "all",
      "description": "Analysis and planning agent - restricted to prevent unintended changes",
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "deep-think": {
      "mode": "all",
      "description": "Deep reasoning agent with maximum thinking budget for complex problem solving",
      "model": "anthropic/claude-sonnet-4-5-deep",
      "reasoningEffort": "high",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "webfetch": true
      },
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  },
  // TUI settings
  "tui": {
    "scroll_speed": 1,
    "scroll_acceleration": {
      "enabled": true
    }
  },
  // Sharing settings
  "share": "manual",
  // Experimental features
  "experimental": {
    "batch_tool": true
  }
}
