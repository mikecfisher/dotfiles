# ==== THEME ====
# Base colors and opacity
theme = Catppuccin Macchiato
background-opacity = 0.98
background-blur = 10
font-family = "JetBrainsMono Nerd Font"
font-size = 18

# Visual refinements for split panes
unfocused-split-opacity = 0.5
alpha-blending = linear-corrected

confirm-close-surface = false

# ==== APPEARANCE ====
# Disable system notifications from the terminal
desktop-notifications = false

# Inherit working directory when opening new windows/tabs
window-inherit-working-directory = true

# Remove window decorations (title bar, etc)
# window-decoration = auto

# Swap foreground/background colors in selected text
selection-invert-fg-bg = false

# Window padding and persistence
window-padding-x = 4
window-padding-y = 8
window-save-state = always
window-vsync = true

split-divider-color =#33008a

# ==== SHELL INTEGRATION ====
# Enable shell features (cursor shape changes, sudo detection, window titles)
shell-integration = fish
shell-integration-features = cursor,sudo,title

# ==== CLIPBOARD BEHAVIOR ====
# Automatically trim trailing spaces when copying
clipboard-trim-trailing-spaces = true
# Prevent accidental paste execution
clipboard-paste-protection = true
# Copy selected text to clipboard
copy-on-select = clipboard

cursor-style = block

# ==== MOUSE BEHAVIOR ====
# Hide mouse cursor while typing
mouse-hide-while-typing = true
# Allow moving cursor with alt/option+click
cursor-click-to-move = true

# ==== PERFORMANCE ====
# Increase scrollback buffer (default is smaller)
scrollback-limit = 9000000

# ==== SPLITS ====
# Create splits
keybind = cmd+l=new_split:right
keybind = cmd+j=new_split:down
keybind = cmd+k=new_split:up

# Navigate between splits (vim-style)
# performable: only triggers if action is possible, otherwise passes key through
keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right

# Toggle split zoom (focus on current split)
keybind = cmd+shift+z=toggle_split_zoom

# Equalize all split sizes
keybind = cmd+shift+e=equalize_splits

focus-follows-mouse = true

keybind = cmd+r=reload_config

window-subtitle = false


title = " "

# ==== MACOS SPECIFIC ====
# Make option key behave like alt
macos-option-as-alt = true
# Handle secure input automatically
macos-auto-secure-input = true

macos-titlebar-style = tabs
keybind = shift+enter=text:\n
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+left=unbind
keybind = alt+l=unbind

# ==== TABS ====
# New tab (cmd+t is default but adding for clarity)
keybind = cmd+t=new_tab
# Close tab
keybind = cmd+w=close_surface
# Navigate between tabs
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
# Change window/tab title
keybind = cmd+shift+r=prompt_surface_title
# Tab overview (visual tab switcher)
keybind = cmd+shift+o=toggle_tab_overview
# Jump to specific tabs (1-9)
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7
keybind = cmd+8=goto_tab:8
keybind = cmd+9=last_tab
