# ============================================================================
# Homebrew & XDG Directories
# ============================================================================
set -l brew_bin
if test -x /opt/homebrew/bin/brew
    set brew_bin /opt/homebrew/bin/brew
else if test -x /usr/local/bin/brew
    set brew_bin /usr/local/bin/brew
else if command -q brew
    set brew_bin (command -s brew)
end

if test -n "$brew_bin"
    # Homebrew environment (sets PATH, MANPATH, INFOPATH, HOMEBREW_PREFIX, etc.)
    eval ($brew_bin shellenv)
end

# XDG Base Directories
set -gx XDG_CONFIG_HOME $HOME/.config
set -gx XDG_DATA_HOME $HOME/.local/share
set -gx XDG_CACHE_HOME $HOME/.cache

# Claude CLI
fish_add_path $HOME/.claude/local

# ============================================================================
# DEVELOPMENT ENVIRONMENT VARIABLES
# ============================================================================
# Node.js SSL certificates
for node_extra_ca_cert in "$HOME/Library/Application Support/mkcert/rootCA.pem" "$HOME/.local/share/mkcert/rootCA.pem"
    if test -f "$node_extra_ca_cert"
        set -gx NODE_EXTRA_CA_CERTS "$node_extra_ca_cert"
        break
    end
end

# Node.js package managers & options
set -gx BUN_INSTALL "$HOME/.bun"
set -gx PNPM_HOME "$HOME/.local/share/pnpm"
fish_add_path --move --path $PNPM_HOME/bin $PNPM_HOME
set -gx NODE_OPTIONS --no-deprecation

# Android SDK
set -gx ANDROID_HOME "$HOME/Library/Android/sdk"
set -gx ANDROID_SDK_ROOT "$HOME/Library/Android/sdk"

# Ruby compilation flags
if set -q HOMEBREW_PREFIX; and test -d "$HOMEBREW_PREFIX/opt/ruby"
    set -gx LDFLAGS "-L$HOMEBREW_PREFIX/opt/ruby/lib"
    set -gx CPPFLAGS "-I$HOMEBREW_PREFIX/opt/ruby/include"
end

function __read_keychain_secret --argument-names service
    if not command -q security
        return 0
    end

    if command -q timeout
        timeout 2 security find-generic-password -a $USER -s "$service" -w 2>/dev/null; or true
    else if command -q gtimeout
        gtimeout 2 security find-generic-password -a $USER -s "$service" -w 2>/dev/null; or true
    else
        security find-generic-password -a $USER -s "$service" -w 2>/dev/null; or true
    end
end

# API Keys (loaded at login when present in macOS Keychain)
set -gx ANTHROPIC_API_KEY (__read_keychain_secret anthropic_api_key)
#set -gx HASS_TOKEN (__read_keychain_secret homeassistant_token_api_key)
#set -gx OPENAI_API_KEY (__read_keychain_secret openai_api_key)
#set -gx HASS_SERVER "http://homeassistant.local:8123"

# ============================================================================
# FNM Environment for Node Version Management
# ============================================================================
if status --is-interactive; and command -q fnm
    # Ensure fnm sets up its Node environment on every new session.
    fnm env --use-on-cd --shell fish | source
end

#============================================================================
# Interactive Shell Settings
# ==========================================================================
if status is-interactive
    # Initialize zoxide
    if command -q zoxide
        zoxide init fish | source
        alias cd="z" # use zoxide for directory switching
    end

    # Aliases
    alias y="yazi"
    alias lg="lazygit"
    alias cat="bat"
    alias edit-fish="nvim ~/.config/fish/config.fish"
    alias reload-fish="source ~/.config/fish/config.fish"

    alias lvim='env NVIM_APPNAME=nvim-lazy nvim'
    alias lv='env NVIM_APPNAME=nvim-lazy nvim'
    if test -x "$HOME/.claude/local/claude"
        alias claude="$HOME/.claude/local/claude"
    end
    alias oc="opencode"
    fish_vi_key_bindings
end

# Brew Wrapper
if command -q brew
    set -l brew_prefix (brew --prefix)
    if test -f "$brew_prefix/etc/brew-wrap.fish"
        source "$brew_prefix/etc/brew-wrap.fish"

        function _post_brewfile_update
            echo "Brewfile was updated!"
            ~/.local/bin/my-scripts/update-packages-yaml.ts
        end
    end
end

# # Basic prompt structure
# set --global tide_left_prompt_items os pwd git node rustc go python
# set --global tide_right_prompt_items time

set -g fish_greeting

function cursor
    if test -x /usr/local/bin/cursor
        command /usr/local/bin/cursor $argv
    else if test -x /opt/homebrew/bin/cursor
        command /opt/homebrew/bin/cursor $argv
    else if test -x "/Applications/Cursor.app/Contents/Resources/app/bin/cursor"
        command "/Applications/Cursor.app/Contents/Resources/app/bin/cursor" $argv
    else
        echo "cursor command not found" >&2
        return 127
    end
end

# bun
set --export BUN_INSTALL "$HOME/.bun"
fish_add_path $BUN_INSTALL/bin

if command -q starship
    starship init fish | source
end

# Added by OrbStack: command-line tools and integration
# This won't be added again if you remove it.
source ~/.orbstack/shell/init2.fish 2>/dev/null || :

if status is-interactive
    # remove the Alt-L directory-listing shortcut
    bind -e \el
end

alias gconf 'nvim ~/.config/ghostty/config'

function sst-tunnel
    # destroy all stale utun devices
    for dev in (ifconfig | awk '/utun[0-9]+:/ {print substr($1,1,length($1)-1)}')
        sudo ifconfig $dev destroy 2>/dev/null
    end

    # start SST tunnel
    bun sst tunnel --print-logs --verbose
end

# opencode
fish_add_path $HOME/.opencode/bin
fish_add_path $HOME/.local/bin

